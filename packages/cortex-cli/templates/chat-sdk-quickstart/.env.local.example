# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Auth Configuration (REQUIRED)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Auth.js secret for JWT signing and encryption
# Generate with: openssl rand -base64 32
# Or visit: https://generate-secret.vercel.app/32
AUTH_SECRET=your-auth-secret-here

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI Provider Configuration (REQUIRED - choose one)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Option 1: Vercel AI Gateway (recommended for Vercel deployments)
# Instructions: https://vercel.com/ai-gateway
# For Vercel deployments: OIDC tokens are used automatically
# For non-Vercel deployments: API key required
# AI_GATEWAY_API_KEY=your-ai-gateway-api-key

# Option 2: OpenAI Direct (required if not using AI Gateway)
# Get this from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Cortex Memory Configuration (REQUIRED)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Your Convex deployment URL
# Get this from: https://dashboard.convex.dev
# This is auto-set when you run: pnpm convex:dev
CONVEX_URL=https://your-project.convex.cloud

# Memory space identifier for multi-tenant isolation
# Each memory space is completely isolated
# Default: chat-sdk-demo
MEMORY_SPACE_ID=chat-sdk-demo

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Cortex Fact Extraction (Recommended)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enable automatic LLM-powered fact extraction from conversations
# Extracts: preferences, identity, relationships, opinions
# Default: true
CORTEX_FACT_EXTRACTION=true

# Model for fact extraction
# Smaller models are faster and cheaper, but may miss nuance
# Options: gpt-4o-mini (fast), gpt-4o (accurate)
# Default: gpt-4o-mini
CORTEX_FACT_EXTRACTION_MODEL=gpt-4o-mini

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OAuth Providers (Optional - configure at least one for auth)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# GitHub OAuth
# Create app at: https://github.com/settings/applications/new
# AUTH_GITHUB_ID=your-github-oauth-app-id
# AUTH_GITHUB_SECRET=your-github-oauth-app-secret

# Google OAuth
# Create credentials at: https://console.cloud.google.com/apis/credentials
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Optional: Graph Database
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enable automatic graph sync for entity relationships
# Requires Neo4j or Memgraph connection below
# CORTEX_GRAPH_SYNC=true

# Neo4j connection
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your-password

# Or Memgraph connection (alternative to Neo4j)
# MEMGRAPH_URI=bolt://localhost:7687
# MEMGRAPH_USERNAME=
# MEMGRAPH_PASSWORD=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Optional: Redis for Resumable Streams
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enable resumable streams across page refreshes
# Instructions: https://vercel.com/docs/redis
# REDIS_URL=redis://...

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Optional: Vercel Analytics
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Enable Vercel Analytics (automatically enabled on Vercel)
# VERCEL_ANALYTICS=true
