{
  "name": "@cortexmemory/vercel-ai-provider",
  "version": "0.36.0",
  "description": "Cortex Memory Provider for Vercel AI SDK - Add persistent memory with enhanced streaming capabilities to any AI application",
  "type": "module",
  "main": "./dist/src/index.cjs",
  "module": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "keywords": [
    "ai",
    "vercel",
    "ai-sdk",
    "vercel-ai-sdk",
    "memory",
    "persistent-memory",
    "cortex",
    "self-hosted",
    "convex",
    "nextjs",
    "react",
    "hooks",
    "llm",
    "openai",
    "anthropic",
    "streaming",
    "chat",
    "conversation",
    "multi-tenant",
    "semantic-search",
    "embeddings",
    "rag",
    "typescript"
  ],
  "author": "Saint Nick LLC",
  "license": "FSL-1.1-Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SaintNick1214/Project-Cortex.git",
    "directory": "packages/vercel-ai-provider"
  },
  "bugs": {
    "url": "https://github.com/SaintNick1214/Project-Cortex/issues"
  },
  "homepage": "https://github.com/SaintNick1214/Project-Cortex/tree/main/packages/vercel-ai-provider#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts react/index.ts --format cjs,esm --dts --clean",
    "build:watch": "tsup src/index.ts react/index.ts --format cjs,esm --dts --watch",
    "clean": "rimraf dist",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:e2e": "node --experimental-vm-modules $(npm root)/.bin/jest --selectProjects e2e",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --selectProjects unit integration",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "ai": "^3.0.0 || ^4.0.0 || ^5.0.0 || ^6.0.0",
    "convex": "^1.28.2",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@cortexmemory/sdk": "*"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.19",
    "@ai-sdk/anthropic": "^3.0.23",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.9",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
